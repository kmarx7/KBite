# Supabase (https://supabase.com/dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 카카오맵 JavaScript 키 (https://developers.kakao.com)
NEXT_PUBLIC_KAKAO_MAP_KEY=

# 토스페이먼츠 (Phase 2 — 테스트 키부터)
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Resend 이메일 (https://resend.com)
RESEND_API_KEY=

# 관리자 대시보드 비밀번호 (서버 전용)
ADMIN_SECRET=

# Vercel Cron 인증 (서버 전용 — Vercel 대시보드 환경변수에도 동일 값 설정)
CRON_SECRET=

# PostHog 분석 (선택 — 없으면 추적 비활성)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# 국세청 사업자 진위확인 (data.go.kr 발급, 선택 — 없으면 검증 생략)
